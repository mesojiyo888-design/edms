<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE tiles-definitions PUBLIC
        "-//Apache Software Foundation//DTD Tiles Configuration 3.0//EN"
        "http://tiles.apache.org/dtds/tiles-config_3_0.dtd">
<tiles-definitions>

    <!-- 공통 기본 레이아웃 정의 -->
    <definition name="default-layout" template="/WEB-INF/jsp/layout/defaultLayout.jsp">
        <put-attribute name="header" value="/WEB-INF/jsp/layout/header.jsp" />
        <put-attribute name="footer" value="/WEB-INF/jsp/layout/footer.jsp" />
    </definition>

    <!-- ComMsg.modalUrl로 AJAX 로드되는 팝업 화면: 공통 헤더/푸터 없이 콘텐츠만 렌더링.
         컨트롤러가 리턴하는 뷰 이름이 "Popup"으로 끝나면 이 정의가 매칭된다.
         Tiles는 와일드카드 정의를 선언 순서대로 검사해 먼저 매칭되는 것을 쓰므로,
         반드시 아래의 범용 "*/*" 계열 정의보다 위에 선언되어 있어야 한다.
         새 팝업 화면을 추가할 때는 이 파일을 건드릴 필요 없이 뷰 이름/JSP 파일명
         끝에 "Popup"만 붙이면 된다. 예) batch/batchFormPopup → /WEB-INF/jsp/batch/batchFormPopup.jsp

         주의: Tiles 와일드카드는 "*" 하나가 경로 세그먼트 하나만 매칭하고 재귀적으로
         하위 depth까지 커버하지 못한다. 그래서 뷰 이름 depth(2~4단계)별로 패턴을 각각
         선언해야 한다. 새로운 depth(5단계 이상)가 필요해지면 아래 패턴에 한 줄 더 추가. -->
    <definition name="*/*Popup" template="/WEB-INF/jsp/{1}/{2}Popup.jsp" />
    <definition name="*/*/*Popup" template="/WEB-INF/jsp/{1}/{2}/{3}Popup.jsp" />
    <definition name="*/*/*/*Popup" template="/WEB-INF/jsp/{1}/{2}/{3}/{4}Popup.jsp" />

    <!-- 기본 레이아웃 (뷰 이름 depth별로 각각 선언 - 위 Popup 정의와 동일한 이유) -->
    <definition name="*/*" extends="default-layout">
        <put-attribute name="body" value="/WEB-INF/jsp/{1}/{2}.jsp" />
    </definition>
    <definition name="*/*/*" extends="default-layout">
        <put-attribute name="body" value="/WEB-INF/jsp/{1}/{2}/{3}.jsp" />
    </definition>
    <definition name="*/*/*/*" extends="default-layout">
        <put-attribute name="body" value="/WEB-INF/jsp/{1}/{2}/{3}/{4}.jsp" />
    </definition>

</tiles-definitions>